{
  "expo": {
    "name": "lakbayph",
    "slug": "lakbayph",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/brand/lakbayph-icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/brand/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "splash": {
        "backgroundColor": "#ffffff",
        "image": "./assets/images/brand/splash-icon.png",
        "resizeMode": "contain",
        "dark": {
          "backgroundColor": "#111111",
          "image": "./assets/images/brand/splash-icon.png",
          "resizeMode": "contain"
        }
      }
    },
    "android": {
      "splash": {
        "backgroundColor": "#ffffff",
        "image": "./assets/images/brand/splash-icon.png",
        "resizeMode": "contain",
        "dark": {
          "backgroundColor": "#111111",
          "image": "./assets/images/brand/splash-icon.png",
          "resizeMode": "contain"
        }
      },
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/brand/lakbayph-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.shadow882026.lakbayph",
      "permissions": []
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "plugins": [
      "expo-updates",
      "expo-sqlite",
      "expo-font",
      [
        "expo-image-picker",
        {
          "photosPermission": "LakbayPH uses your photo library to let you attach photos to your trip activities."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "5d252f1c-5788-4933-aa73-23656630f5ad"
      }
    },
    "owner": "wil.soriano"
  }
}
